<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- 允许后台通知直接弹出 Heads-up 悬浮窗 -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="true"
        android:enableOnBackInvokedCallback="true">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- ============================================================
             RestartReceiver：捕捉一切可能间接唤醒进程的系统事件
             ============================================================ -->
        <receiver
            android:name=".RestartReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.USER_PRESENT" />
                <!-- 时间/时区变更：系统会短暂唤醒注册了这些广播的进程 -->
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <!-- 应用更新后自动恢复 -->
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <!-- 电源状态变化：系统在电源事件时会短暂放宽后台限制 -->
                <action android:name="android.intent.action.ACTION_POWER_CONNECTED" />
                <action android:name="android.intent.action.ACTION_POWER_DISCONNECTED" />
            </intent-filter>
        </receiver>

        <!-- ============================================================
             AlarmReceiver：闹钟驱动的后台检查触发器
             由 BackgroundAlarmScheduler 设置的 AlarmManager 触发
             ============================================================ -->
        <receiver
            android:name=".AlarmReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="terminal.negentropy.life.ALARM_PRIMARY" />
                <action android:name="terminal.negentropy.life.ALARM_BACKUP" />
                <action android:name="terminal.negentropy.life.ALARM_PRIMARY_FALLBACK" />
                <action android:name="terminal.negentropy.life.ALARM_BACKUP_WINDOW" />
            </intent-filter>
        </receiver>

        <!-- ============================================================
             KeepAliveService：前台持久服务
             mediaPlayback + specialUse + dataSync 三类型组合：
             mediaPlayback 让系统误以为这是音乐播放器，杀后台容忍度最高
             ============================================================ -->
        <service
            android:name=".KeepAliveService"
            android:exported="false"
            android:foregroundServiceType="specialUse|dataSync|mediaPlayback">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="AI_BACKGROUND_COMPANION_FOR_RULES_GAME" />
        </service>

        <!-- ============================================================
             KeepAliveAccessibilityService：无障碍服务保活（方案 6）
             无障碍服务在系统中享有最高优先级，ColorOS 等国产 ROM
             几乎不会杀掉，杀了会影响残障用户辅助功能。
             需要用户在"设置→无障碍"中手动开启。
             ============================================================ -->
        <service
            android:name=".KeepAliveAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>

</manifest>
